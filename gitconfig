[include]
	path = .gitconfig-user
	path = .gitconfig-diff
[alias]
	l = log --pretty=tformat:'%C(yellow)%h%Creset - %C(cyan)%an%Creset - %s %Cgreen(%cr)%Creset'
	hist = log --graph --decorate --oneline --all
	last = log -1 HEAD
	blame = -w -C -C -C
[column]
	ui = auto
[branch]
	autoSetupMerge = true  # imply `--track` when the starting point is a remote-tracking branch
	sort = -committerdate
[fetch]
	prune = true  # imply `--prune`
[push]
	autoSetupRemote = true  # imply `--set-upstream`
[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true
[merge]
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
	mnemonicPrefix = true
[difftool]
	prompt = false
[filter "lfs"]
	# configs inserted on `git lfs install`
	# see: https://github.com/git-lfs/git-lfs/tree/main/docs
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
